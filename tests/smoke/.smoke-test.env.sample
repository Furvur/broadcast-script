# Smoke Test Credentials
# Copy this file to .smoke-test.env and fill in your values:
#   cp .smoke-test.env.sample .smoke-test.env
#
# Only BROADCAST_LICENSE_KEY is required. Registry credentials
# are fetched automatically from the license API.

# Valid Broadcast license key (required)
BROADCAST_LICENSE_KEY=

# Docker registry credentials (optional — auto-fetched from license API if omitted)
# BROADCAST_REGISTRY_URL=
# BROADCAST_REGISTRY_LOGIN=
# BROADCAST_REGISTRY_PASSWORD=
